            /* Thuật Linh Động Hóa (TRIZ 15): Dòng chảy màu sắc liên tục lôi kéo sự chú ý */
            @keyframes panGradient {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .moving-gradient-banner {
                /* Dải màu: Vàng kem - Vàng ánh kim - Vàng cam - Vàng hoàng kim */
                background: linear-gradient(270deg, #f4edca, #f8df81, #ffd700, #f8df81, #f4edca);
                background-size: 400% 400%;
                animation: panGradient 1s ease-in-out infinite;
                text-align: center;
                padding: 15px;
                font-weight: bold;
                font-family: sans-serif;
                color: #2c3e50;
                /* Xanh than sẫm chống chói */
                border-bottom: 2px solid rgba(255, 255, 255, 0.4);
            }
        </style>

